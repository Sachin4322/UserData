@Library('Shared') _

pipeline {
    agent {
        label 'dev'
    }

    stages {

        stage('Code Clone') {
            steps {
                script {
                    clone('https://github.com/Sachin4322/UserData.git', 'master')
                }
            }
        }

        stage('Trivy File System Scan') {
            steps {
                script {
                    trivy()
                }
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t two-tier-flask-app:latest .'
            }
        }

        stage('Test') {
            steps {
                echo 'All required test cases have passed.'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker_push('dockerhubcicd', 'two-tier-flask-app')
                }
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d --build'
            }
        }
    }

    post {
        success {
            emailext(
                to: 'sachinshinde390@gmail.com',
                subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build Status : SUCCESS

Job Name     : ${env.JOB_NAME}
Build Number : ${env.BUILD_NUMBER}
Build URL    : ${env.BUILD_URL}

The CI/CD pipeline completed successfully.
"""
            )
        }

        failure {
            emailext(
                to: 'sachinshinde390@gmail.com',
                subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build Status : FAILED

Job Name     : ${env.JOB_NAME}
Build Number : ${env.BUILD_NUMBER}
Build URL    : ${env.BUILD_URL}

Please check the Jenkins console logs for more details.
"""
            )
        }
    }
}
