pipeline {
    agent {
        label 'dev'
    }

    stages {

        stage('Code Clone') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Sachin4322/UserData.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t two-tier-flask-app:latest .'
            }
        }

        stage('Test') {
            steps {
                echo 'All required test cases have passed.'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhubcicd',
                    usernameVariable: 'dockerHubUser',
                    passwordVariable: 'dockerHubPass'
                )]) {

                    sh '''
                    echo "$dockerHubPass" | docker login -u "$dockerHubUser" --password-stdin
                    docker tag two-tier-flask-app:latest $dockerHubUser/two-tier-flask-app:latest
                    docker push $dockerHubUser/two-tier-flask-app:latest
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d --build'
            }
        }
    }
post {
    success {
        emailext(
            subject: 'Build is Successful',
            body: 'Your build is successful...!',
            to: 'sachinshinde390@gmail.com'
        )
    }

    failure {
        emailext(
            subject: 'Build Failed',
            body: 'Your build has failed...!',
            to: 'sachinshinde390@gmail.com'
        )
    }
}
}
