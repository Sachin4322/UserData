@Library('Shared') _
pipeline {
    agent {
        label 'dev'
    }

    stages {

        stage('Code Clone') {
            steps {
                script{
                    clone('https://github.com/Sachin4322/UserData.git', 'master')
                }
            }
        }
        stage ('Trivy File Sysytem Scan'){
            steps {
                script{
                    trivy_fs()
                }
            }
        } 

        stage('Build') {
            steps {
                sh 'docker build -t two-tier-flask-app:latest .'
            }
        }

        stage('Test') {
            steps {
                echo 'All required test cases have passed.'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker_push('dockerhubcicd','two-tier-flask-app')
                }
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d --build'
            }
        }
    }
post {
    success {
        emailext(
            subject: 'Build is Successful',
            body: 'Your build is successful...!',
            to: 'sachinshinde390@gmail.com'
        )
    }

    failure {
        emailext(
            subject: 'Build Failed',
            body: 'Your build has failed...!',
            to: 'sachinshinde390@gmail.com'
        )
    }
}
}
